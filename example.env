PORT=4000
NODE_ENV=development

# ── JWT Secrets (generate with: openssl rand -hex 64) ─────────────
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_another_64_byte_hex_secret

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=YourApp

# ── SMS Gateway (Fast2SMS) ─────────────────────────────────────────
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_URL=https://www.fast2sms.com/dev/bulkV2

# ── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── API versioning ─────────────────────────────────────────────────
BACKEND_VERSION=v1

# Google Calendar OAuth
# Register this exact redirect URI in Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google-calendar/oauth/callback
GOOGLE_CALENDAR_ALLOWED_APP_REDIRECTS=apnogarage://
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret
